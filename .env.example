# ---------- السيرفر ----------
PORT=3000
JWT_SECRET=change_this_to_a_long_random_string

# ---------- الذكاء الاصطناعي ----------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
AI_MODEL=claude-haiku-4-5-20251001

# ---------- واتساب ----------
# اختر المزود: wasender (رخيص وموصى فيه)، selfhosted، green، ultramsg، أو cloud (الرسمي)
WA_PROVIDER=wasender

# --- WasenderAPI (لو WA_PROVIDER=wasender) — wasenderapi.com ---
WASENDER_API_KEY=
WASENDER_WEBHOOK_SECRET=

# --- Green API (لو WA_PROVIDER=green) ---
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# --- UltraMsg (لو WA_PROVIDER=ultramsg) ---
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=

# --- Meta WhatsApp Cloud API (لو WA_PROVIDER=cloud) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=choose_your_own_verification_word

# ---------- إرسال نسخة الطلبات ----------
# dashboard فقط، أو whatsapp لإرسال نسخة لرقم/جروب إضافي
ORDER_DESTINATION_MODE=dashboard
ORDER_DESTINATION_TARGET=

# ---------- الإيميل (استرجاع كلمة المرور + دعوات الموظفين) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@saberjo.com
